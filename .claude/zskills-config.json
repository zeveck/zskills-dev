{
  "$schema": "./zskills-config.schema.json",
  "project_name": "zskills",
  "timezone": "America/New_York",

  "execution": {
    "landing": "pr",
    "main_protected": true,
    "branch_prefix": "feat/"
  },

  "commit": {
    "co_author": "Claude Opus 4.7 (1M context) <noreply@anthropic.com>"
  },

  "testing": {
    "unit_cmd": "bash tests/test-hooks.sh",
    "full_cmd": "bash tests/test-hooks.sh",
    "output_file": ".test-results.txt",
    "file_patterns": ["tests/**/*.sh"]
  },

  "dev_server": {
    "cmd": "",
    "port_script": "",
    "main_repo_path": "/workspaces/zskills"
  },

  "ui": {
    "file_patterns": "",
    "auth_bypass": ""
  },

  "ci": {
    "auto_fix": true,
    "max_fix_attempts": 2
  },

  "agents": {
    "min_model": "auto"
  }
}
